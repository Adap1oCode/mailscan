# Required — shared secret for X-API-Key header auth
MAILSCAN_API_KEY=change-me-to-a-strong-random-string

# Required on Linux/Mac — path to tesseract binary
# Find it with: which tesseract
TESSERACT_CMD=/usr/bin/tesseract

# Optional — HTTP port (default 8000)
PORT=8000

# Optional — Redis URL for async job queue (Celery)
# If not set, /process falls back to synchronous processing
# Format: redis://<host>:<port>/<db>
REDIS_URL=redis://redis:6379/0

# Optional — address parser ('regex' or 'libpostal')
# regex:    lightweight, fast, good for clean scans (default)
# libpostal: ML-based, handles OCR noise, requires libpostal compiled in Docker
ADDRESS_PARSER=regex

# Optional — cap the longest rendered page side in pixels (default 4500).
# Bounds peak memory per page so very large / high-DPI scans can't OOM the
# container. A4 @ 300 DPI is ~3508px; lower this on small-RAM hosts.
MAILSCAN_MAX_RENDER_PX=4500

# Optional — hard ceiling (ms) for a single Data Matrix barcode scan (default
# 10000). Bounds latency on barcode-free pages, which otherwise scan the whole
# high-DPI image.
MAILSCAN_DMTX_TIMEOUT_MS=10000

# Optional — minimum fuzzy-match score 0–100 for client matching (default 85).
MAILSCAN_MATCH_CUTOFF=85
